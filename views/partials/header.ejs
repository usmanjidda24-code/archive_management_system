<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nexus | Web Archive Management System</title>
    <!-- Modern Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --primary: #6366f1;
            --primary-glow: rgba(99, 102, 241, 0.5);
            --secondary: #8b5cf6;
            --accent: #ec4899;
            --dark-bg: #030712;
            --glass-bg: rgba(17, 24, 39, 0.7);
            --glass-border: rgba(255, 255, 255, 0.08);
            --text-main: #ffffff;
            --text-muted: #d1d5db;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--dark-bg);
            color: var(--text-main);
            min-height: 100vh;
        }

        h1, h2, h3, h4, h5, h6, .brand-font {
            font-family: 'Outfit', sans-serif;
        }

        /* Glass Sidebar & Nav */
        .navbar-glass {
            background: rgba(3, 7, 18, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--glass-border);
        }
        
        .sidebar {
            min-height: calc(100vh - 69px);
            background: rgba(255, 255, 255, 0.02);
            border-right: 1px solid var(--glass-border);
        }
        
        .sidebar-link {
            color: var(--text-muted);
            text-decoration: none;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            border-radius: 12px;
            margin-bottom: 8px;
            transition: all 0.3s ease;
            font-weight: 500;
        }
        
        .sidebar-link:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-main);
            transform: translateX(5px);
        }
        
        .sidebar-link.active {
            background: linear-gradient(135deg, rgba(99,102,241,0.2), rgba(139,92,246,0.2));
            color: var(--text-main);
            border: 1px solid var(--primary-glow);
            box-shadow: 0 0 15px rgba(99,102,241,0.1);
        }

        .brand-icon {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Reusable UI Components */
        .glass-card {
            background: rgba(17, 24, 39, 0.5);
            backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
        }
        
        .glass-header {
            border-bottom: 1px solid var(--glass-border);
            background: rgba(255,255,255,0.02);
        }

        .btn-glow {
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        
        .btn-primary-glow {
            background: linear-gradient(45deg, var(--primary), var(--secondary));
            color: white;
            border: none;
            box-shadow: 0 5px 15px var(--primary-glow);
        }
        
        .btn-primary-glow:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px var(--primary-glow);
            color: white;
        }
        
        .btn-outline-glow {
            background: transparent;
            color: var(--text-main);
            border: 1px solid var(--glass-border);
        }
        .btn-outline-glow:hover {
            background: rgba(255,255,255,0.05);
            color: white;
            border-color: rgba(255,255,255,0.2);
        }

        /* Tables & Forms */
        .table-dark {
            background: transparent;
            color: var(--text-main);
        }
        .table-dark th { background: rgba(255,255,255,0.05); border-bottom: 1px solid var(--glass-border); font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.5px; }
        .table-dark td { border-bottom: 1px solid rgba(255,255,255,0.02); }
        .table-dark tbody tr:hover { background: rgba(255,255,255,0.03); color: white; }
        
        .form-control, .form-select {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--glass-border);
            color: var(--text-main);
        }
        .form-control:focus, .form-select:focus {
            background: rgba(255,255,255,0.06);
            border-color: var(--primary);
            box-shadow: 0 0 0 0.25rem var(--primary-glow);
            color: white;
        }
        .form-control::placeholder { color: rgba(255,255,255,0.3); }
        .input-group-text {
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--glass-border);
            color: var(--text-muted);
        }
        .text-muted {
            color: var(--text-muted) !important;
        }
        
        /* Stats Cards */
        .stat-card {
            border-radius: 16px;
            padding: 24px;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            transition: transform 0.3s ease;
        }
        .stat-card:hover { transform: translateY(-5px); }
        .stat-card::before {
            content: ''; position: absolute; top:0; left:0; right:0; bottom:0; opacity: 0.1;
            background: linear-gradient(45deg, transparent, white);
        }
        .stat-primary { background: linear-gradient(135deg, #4f46e5, #7c3aed); }
        .stat-success { background: linear-gradient(135deg, #059669, #10b981); }
        .stat-info { background: linear-gradient(135deg, #0284c7, #0ea5e9); }
        
    </style>
</head>
<body>
<% if (typeof user !== 'undefined' && user.userId) { %>
    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-glass sticky-top py-3">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold" href="/dashboard" style="font-family: 'Outfit';">
                <i class="bi bi-heptagon-fill brand-icon me-2"></i>Nexus<span class="fw-light ms-1 opacity-75">Archive</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="topNav">
                <ul class="navbar-nav align-items-center">
                    <li class="nav-item d-flex align-items-center me-4">
                        <div class="rounded-circle bg-secondary d-flex justify-content-center align-items-center me-2 text-white fw-bold" style="width: 32px; height: 32px; font-size: 14px;">
                            <%= user.fullName ? user.fullName.charAt(0).toUpperCase() : 'U' %>
                        </div>
                        <span class="nav-link text-white p-0"> <%= user.fullName %></span>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-glow btn-sm rounded-pill px-3" href="/logout"><i class="bi bi-power me-1"></i>Disconnect</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 d-none d-md-block sidebar py-4 px-3">
                <div class="text-uppercase text-muted small fw-bold mb-3 px-3 tracking-wide" style="letter-spacing: 1px;">Core System</div>
                <a href="/dashboard" class="sidebar-link <%= typeof currentPath !== 'undefined' && currentPath === 'dashboard' ? 'active' : '' %>">
                    <i class="bi bi-speedometer2 me-3 fs-5"></i>Overview
                </a>
                <a href="/archives" class="sidebar-link <%= typeof currentPath !== 'undefined' && currentPath === 'archives' ? 'active' : '' %>">
                    <i class="bi bi-folder2-open me-3 fs-5"></i>Document Vault
                </a>
                
                <div class="text-uppercase text-muted small fw-bold mb-3 mt-4 px-3 tracking-wide" style="letter-spacing: 1px;">Operations</div>
                <a href="/archives/upload" class="sidebar-link <%= typeof currentPath !== 'undefined' && currentPath === 'upload' ? 'active' : '' %>">
                    <i class="bi bi-cloud-arrow-up me-3 fs-5"></i>Upload Artifact
                </a>
            </div>
            <!-- Main Content -->
            <div class="col-md-10 py-4 px-lg-5">
                <% if (typeof successMsg !== 'undefined' && successMsg.length > 0) { %>
                    <div class="alert alert-success border-success border-opacity-50 bg-success bg-opacity-10 text-success alert-dismissible fade show rounded-3" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i><%= successMsg %>
                        <button type="button" class="btn-close btn-close-white opacity-50" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                <% if (typeof errorMsg !== 'undefined' && errorMsg.length > 0) { %>
                    <div class="alert alert-danger border-danger border-opacity-50 bg-danger bg-opacity-10 text-danger alert-dismissible fade show rounded-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i><%= errorMsg %>
                        <button type="button" class="btn-close btn-close-white opacity-50" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
<% } %>
