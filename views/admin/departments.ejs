<%- include('../partials/header') %>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="bi bi-building text-primary me-2"></i>Departments Management</h2>
        <button class="btn btn-primary-glow" data-bs-toggle="modal" data-bs-target="#addDepartmentModal">
            <i class="bi bi-plus-lg me-1"></i> Add Department
        </button>
    </div>

    <!-- Admin Sub-navigation -->
    <ul class="nav nav-pills mb-4 pb-2 border-bottom border-secondary border-opacity-25">
        <li class="nav-item">
            <a class="nav-link text-white rounded-pill px-4" href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white rounded-pill px-4" href="/admin/users"><i class="bi bi-people me-2"></i>Users</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white rounded-pill px-4" href="/admin/categories"><i class="bi bi-tags me-2"></i>Categories</a>
        </li>
        <li class="nav-item">
            <a class="nav-link active rounded-pill px-4" href="/admin/departments"><i class="bi bi-building me-2"></i>Departments</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white rounded-pill px-4" href="/admin/logs"><i class="bi bi-journal-text me-2"></i>Activity Logs</a>
        </li>
    </ul>

    <div class="row">
        <div class="col-md-8">
            <div class="glass-card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th class="ps-4">ID</th>
                                    <th>Department Name</th>
                                    <th>Created At</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (departments && departments.length > 0) { %>
                                    <% departments.forEach(d => { %>
                                        <tr>
                                            <td class="ps-4 text-muted">#<%= d.id %></td>
                                            <td class="fw-medium text-white"><%= d.name %></td>
                                            <td class="text-muted small"><%= new Date(d.created_at).toLocaleDateString() %></td>
                                            <td class="text-end pe-4">
                                                <form action="/admin/departments/delete/<%= d.id %>" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Are you sure? This will set user departments to NULL for users in this department.')">
                                                        <i class="bi bi-trash"></i> Delete
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">No departments found.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Department Modal -->
<div class="modal fade" id="addDepartmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-secondary border-opacity-50 text-white">
            <div class="modal-header border-secondary border-opacity-25">
                <h5 class="modal-title"><i class="bi bi-building-add me-2"></i>Add New Department</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/admin/departments/add" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Department Name</label>
                        <input type="text" name="name" class="form-control" required placeholder="e.g. HR Department">
                    </div>
                </div>
                <div class="modal-footer border-secondary border-opacity-25">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary-glow">Save Department</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
