<%- include('../partials/header') %>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="bi bi-people text-primary me-2"></i>Users Management</h2>
        <button class="btn btn-primary-glow" data-bs-toggle="modal" data-bs-target="#addUserModal">
            <i class="bi bi-plus-lg me-1"></i> Add User
        </button>
    </div>

    <!-- Admin Sub-navigation -->
    <ul class="nav nav-pills mb-4 pb-2 border-bottom border-secondary border-opacity-25">
        <li class="nav-item">
            <a class="nav-link text-white rounded-pill px-4" href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
        </li>
        <li class="nav-item">
            <a class="nav-link active rounded-pill px-4" href="/admin/users"><i class="bi bi-people me-2"></i>Users</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white rounded-pill px-4" href="/admin/categories"><i class="bi bi-tags me-2"></i>Categories</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white rounded-pill px-4" href="/admin/departments"><i class="bi bi-building me-2"></i>Departments</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white rounded-pill px-4" href="/admin/logs"><i class="bi bi-journal-text me-2"></i>Activity Logs</a>
        </li>
    </ul>

    <div class="glass-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th class="ps-4">Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Department</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (users && users.length > 0) { %>
                            <% users.forEach(u => { %>
                                <tr>
                                    <td class="ps-4 fw-medium"><%= u.full_name %></td>
                                    <td class="text-muted"><%= u.email %></td>
                                    <td>
                                        <% if (u.role === 'admin') { %>
                                            <span class="badge bg-danger rounded-pill px-3">Admin</span>
                                        <% } else { %>
                                            <span class="badge bg-primary rounded-pill px-3">Staff</span>
                                        <% } %>
                                    </td>
                                    <td><%= u.dept_name || '-' %></td>
                                    <td class="text-end pe-4">
                                        <% if (u.id !== user.userId) { %>
                                        <form action="/admin/users/delete/<%= u.id %>" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Are you sure you want to delete this user?')">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                        <% } else { %>
                                            <span class="text-muted small">Current User</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No users found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-secondary border-opacity-50 text-white">
            <div class="modal-header border-secondary border-opacity-25">
                <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Add New User</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/admin/users/add" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Full Name</label>
                        <input type="text" name="full_name" class="form-control" required placeholder="John Doe">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Email Address</label>
                        <input type="email" name="email" class="form-control" required placeholder="user@example.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Password</label>
                        <input type="password" name="password" class="form-control" required placeholder="••••••••">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Role</label>
                        <select name="role" class="form-select" required>
                            <option value="staff">Staff</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Department</label>
                        <select name="department_id" class="form-select">
                            <option value="">-- No Department --</option>
                            <% departments.forEach(d => { %>
                                <option value="<%= d.id %>"><%= d.name %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-secondary border-opacity-25">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary-glow">Save User</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
