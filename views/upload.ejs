<%- include('partials/header', { currentPath: 'upload' }) %>

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="d-flex align-items-center mb-4 pb-2 border-bottom border-light border-opacity-10">
            <div class="p-3 bg-primary bg-opacity-10 rounded-circle me-3">
                <i class="bi bi-cloud-arrow-up text-primary fs-3"></i>
            </div>
            <div>
                <h3 class="fw-bold mb-1 brand-font text-white">Upload New Artifact</h3>
                <p class="text-muted mb-0">Securely encrypt and transmit an artifact to the vault</p>
            </div>
        </div>
        
        <div class="glass-card mt-4 overflow-hidden">
            <div class="glass-header p-4">
                <h5 class="mb-0 fw-bold brand-font text-white-50"><i class="bi bi-shield-lock me-2"></i>Zero-Trust Protocol Active</h5>
            </div>
            <div class="card-body p-4 p-md-5">
                <form action="/archives/upload" method="POST" enctype="multipart/form-data">
                    
                    <div class="mb-4">
                        <label class="form-label text-white-50 fw-semibold small text-uppercase tracking-wide">Complete Artifact Designation <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-lg" name="title" required placeholder="e.g. Q4 Financial Audit Report 2026">
                        <div class="form-text text-muted mt-2"><i class="bi bi-info-circle me-1"></i>Ensure a highly descriptive and quantum-searchable title.</div>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label text-white-50 fw-semibold small text-uppercase tracking-wide">Artifact Classification <span class="text-danger">*</span></label>
                        <select class="form-select form-select-lg" name="category_id" required>
                            <option value="">-- Assign Security Clearance --</option>
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat.id %>"><%= cat.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="mb-5 position-relative">
                        <label class="form-label text-white-50 fw-semibold small text-uppercase tracking-wide">Payload Selection <span class="text-danger">*</span></label>
                        <div class="p-4 border border-light border-opacity-25 rounded-3 bg-dark bg-opacity-50 text-center position-relative" style="border-style: dashed !important;">
                            <i class="bi bi-file-earmark-arrow-up display-4 text-primary opacity-50 mb-3 d-block"></i>
                            <input class="form-control form-control-lg bg-transparent border-0 text-white" type="file" name="archive_file" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" required style="box-shadow: none;">
                        </div>
                        <div class="form-text text-muted mt-2"><i class="bi bi-check2-circle text-success me-1"></i>Allowed payload signatures: PDF, DOCX, JPG, PNG. Max packet size: 10MB</div>
                    </div>
                    
                    <div class="d-flex justify-content-end align-items-center mt-5 pt-4 border-top border-light border-opacity-10">
                        <a href="/dashboard" class="btn btn-link text-white-50 text-decoration-none me-4">Abort Uplink</a>
                        <button type="submit" class="btn-glow btn-primary-glow px-4 py-3"><i class="bi bi-lock-fill me-2"></i>Encrypt & Transmit to Vault</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
